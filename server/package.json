    "@koa/router": "^13.1.0",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "koa": "^2.16.1",
    "koa-bodyparser": "^4.4.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
