generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Buyer {
  id               BigInt    @id @default(autoincrement())
  name             String    @db.VarChar(100)
  address          String?   @db.VarChar(500)
  permanentAddress String?   @map("permanent_address") @db.VarChar(500)
  birthday         DateTime? @db.Date
  phone            String?   @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  purchases         Purchase[]
  birthdayReminders BirthdayReminder[]

  @@index([name])
  @@map("buyers")
}

model ProductCategory {
  id                BigInt   @id @default(autoincrement())
  name              String   @db.VarChar(100)
  code              String   @unique @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]
  brands   Brand[]

  @@map("product_categories")
}

model Brand {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  categoryId BigInt?  @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  products Product[]

  @@index([categoryId])
  @@map("brands")
}

model Product {
  id         BigInt   @id @default(autoincrement())
  categoryId BigInt   @map("category_id")
  brandId    BigInt?  @map("brand_id")
  model      String?  @db.VarChar(100)
  name       String   @db.VarChar(200)
  costPrice  Decimal? @map("cost_price") @db.Decimal(12, 2)
  sellPrice  Decimal? @map("sell_price") @db.Decimal(12, 2)
  stock      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category      ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand         Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  purchaseItems PurchaseItem[]

  @@index([categoryId])
  @@index([brandId])
  @@map("products")
}

model Purchase {
  id          BigInt   @id @default(autoincrement())
  buyerId     BigInt   @map("buyer_id")
  purchasedAt DateTime @map("purchased_at")
  note        String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  buyer Buyer          @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  items PurchaseItem[]

  @@index([buyerId, purchasedAt])
  @@map("purchases")
}

model PurchaseItem {
  id         BigInt  @id @default(autoincrement())
  purchaseId BigInt  @map("purchase_id")
  productId  BigInt? @map("product_id")
  name       String   @db.VarChar(200)
  price      Decimal  @db.Decimal(12, 2)
  sellPrice  Decimal? @map("sell_price") @db.Decimal(12, 2)
  quantity   Int      @default(1)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@map("purchase_items")
}

model AppSettings {
  id                      Int      @id @default(1)
  birthdayLeadDays        Int      @default(3) @map("birthday_lead_days")
  birthdayReminderEnabled Boolean  @default(true) @map("birthday_reminder_enabled")
  reminderHour            Int      @default(9) @map("reminder_hour")
  reminderMinute          Int      @default(0) @map("reminder_minute")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

enum ReminderStatus {
  PENDING
  DONE
  SKIPPED
}

model BirthdayReminder {
  id         BigInt         @id @default(autoincrement())
  buyerId    BigInt         @map("buyer_id")
  birthday   DateTime       @db.Date
  leadDays   Int            @map("lead_days")
  status     ReminderStatus @default(PENDING)
  createdAt  DateTime       @default(now()) @map("created_at")
  resolvedAt DateTime?      @map("resolved_at")

  buyer Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([buyerId, birthday])
  @@index([status, createdAt])
  @@map("birthday_reminders")
}
